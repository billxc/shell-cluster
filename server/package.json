{
  "name": "shell-cluster-server",
  "version": "1.0.0",
  "description": "Node.js server for shell-cluster with node-pty and xterm-headless",
  "main": "src/index.js",
  "bin": {
    "shellcluster": "src/cli.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "postinstall": "chmod +x node_modules/node-pty/prebuilds/darwin-arm64/spawn-helper 2>/dev/null || true"
  },
  "dependencies": {
    "node-pty": "^1.0.0",
    "@xterm/headless": "^5.5.0",
    "@xterm/addon-serialize": "^0.13.0",
    "ws": "^8.18.0",
    "@iarna/toml": "^2.2.5",
    "commander": "^12.0.0"
  }
}
